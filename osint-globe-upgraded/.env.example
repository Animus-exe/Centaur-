# Database
DATABASE_URL=postgresql+psycopg://osint:osint@db:5432/osint

# Ingestion cadence
INGEST_FLIGHTS_SECONDS=10
INGEST_CONFLICTS_MINUTES=60
INGEST_PRICES_MINUTES=30
INGEST_FUEL_MINUTES=60
INGEST_CAMERAS_MINUTES=5

# Retention policies
FLIGHT_TRACK_RETENTION_HOURS=24
FUEL_PRICE_RETENTION_HOURS=72
CAMERAS_RETENTION_DAYS=7
STATUS_HISTORY_DAYS=7

# Areas of Interest (AOIs) - flights are fetched only within these regions.
# Leave empty for worldwide default (Europe, N America, Asia, Australia, S America, Africa).
# Format: name,minLat,minLon,maxLat,maxLon;name2,minLat,minLon,maxLat,maxLon
# AOIS=EUROPE,35.0,-10.0,60.0,30.0;NAMERICA,25.0,-125.0,50.0,-65.0;ASIA,5.0,60.0,55.0,150.0;AUSTRALIA,-45.0,110.0,-10.0,155.0

# UCDP token (optional). If empty, conflict areas are still shown using built-in regions (Ukraine, Gaza, Syria, Yemen, Sahel). Set to your token for live UCDP data.
UCDP_TOKEN=

# Override airplanes.live API base if needed (e.g. use http if HTTPS fails from your network)
# AIRPLANES_LIVE_BASE_URL=http://api.airplanes.live/v2

# OpenSky polling controls
OPENSKY_MIN_POLL_SECONDS_ANON=300
OPENSKY_MIN_POLL_SECONDS_AUTH=45
OPENSKY_RATE_LIMIT_COOLDOWN_SECONDS_ANON=900
OPENSKY_RATE_LIMIT_COOLDOWN_SECONDS_AUTH=180
FLIGHTS_STALE_AFTER_SECONDS=180
FLIGHTS_DISPLAY_MAX_AGE_WHEN_RATE_LIMITED_SECONDS=86400
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Cesium Ion token (optional; globe still runs without terrain if empty)
VITE_CESIUM_ION_TOKEN=

# Shodan API key for IP cameras layer (optional; get one at https://account.shodan.io)
SHODAN_API_KEY=
